# Claupiece — Esempio di file .env (per lo sviluppo LOCALE).
# Copia in `.env` e riempi i valori. NON committare `.env` (è in .gitignore).
# In produzione (GitHub Actions / Vercel) questi valori vanno nei SECRET, non in
# un file. Ogni valore: vedi SETUP_TODO.md per come ottenerlo.

# --- Supabase (usare la SERVICE ROLE key, non l'anon) ---
SUPABASE_URL=__TODO_SUPABASE_URL__
SUPABASE_SERVICE_ROLE_KEY=__TODO_SUPABASE_SERVICE_ROLE_KEY__
# La anon key serve SOLO alla web app (client). Non usata dal backend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=__TODO_SUPABASE_ANON_KEY__

# --- Telegram (canale notifiche PERSONALE) ---
# TELEGRAM_CHAT_ID = il TUO chat id (dove arrivano gli alert affare).
TELEGRAM_BOT_TOKEN=__TODO_TELEGRAM_BOT_TOKEN__
TELEGRAM_CHAT_ID=__TODO_TELEGRAM_CHAT_ID__
# URL della dashboard web (per il comando /app del bot). Es. https://claupiece.vercel.app
WEB_APP_URL=

# --- Apify (Vinted via Smart Scraper — l'unico costo, dentro il free tier) ---
APIFY_TOKEN=__TODO_APIFY_TOKEN__

# --- Prezzo di riferimento ---
# CardTrader (API ufficiale, gratis) — OPZIONALE: va abilitata dal supporto CardTrader.
# Se manca, si usa Cardmarket via Apify (stesso APIFY_TOKEN, refresh SETTIMANALE).
# Se mancano entrambi → si usa solo la regola prezzo_max (tetto in €).
CARDTRADER_TOKEN=
# (opz.) override actor/dominio Cardmarket:
# APIFY_CARDMARKET_ACTOR=kazkn/smart-scraper
# CARDMARKET_BASE=https://www.cardmarket.com/en/OnePiece

# --- Gemini (Google AI Studio → API key, scoring a stelle) ---
GEMINI_API_KEY=__TODO_GEMINI_API_KEY__

# --- Finestra oraria / fuso (uso personale) ---
TIMEZONE=Europe/Rome
FINESTRA_DEFAULT=sera        # mattina | pomeriggio | sera

# --- Anagrafica (opzionale) ---
LINGUA_ANAGRAFICA=en

# --- (Futuro) TCG API ---
# TCGAPI_KEY=__TODO_TCGAPI_KEY__
