# Claupiece web — variabili d'ambiente (Vercel / locale).
# Copia in .env.local per lo sviluppo. NON committare .env.local.

# Supabase — l'URL e la ANON key sono pubblici (usati dal client, protetti da RLS).
NEXT_PUBLIC_SUPABASE_URL=__TODO_SUPABASE_URL__
NEXT_PUBLIC_SUPABASE_ANON_KEY=__TODO_SUPABASE_ANON_KEY__

# La SERVICE ROLE key resta SOLO server-side (API routes). Bypassa RLS: mai esporla al client.
SUPABASE_SERVICE_ROLE_KEY=__TODO_SUPABASE_SERVICE_ROLE_KEY__
